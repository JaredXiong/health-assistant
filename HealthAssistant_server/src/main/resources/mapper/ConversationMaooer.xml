<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.healthy.mapper.ConversationMapper">

    <!-- 实体映射 -->
    <resultMap id="BaseResultMap" type="com.healthy.entity.Conversation">
        <id property="id" column="id"/>
        <result property="userId" column="user_id"/>
        <result property="sessionId" column="session_id"/>
        <result property="role" column="role"/>
        <result property="content" column="content"/>
        <result property="createTime" column="create_time"/>
    </resultMap>

    <!-- 根据会话ID查询对话记录 -->
    <select id="selectBySession" resultMap="BaseResultMap">
        SELECT *
        FROM conversation
        WHERE user_id = #{userId}
          AND session_id = #{sessionId}
        ORDER BY create_time
    </select>

    <!-- 插入对话记录 -->
    <insert id="insert" parameterType="com.healthy.entity.Conversation" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO conversation (user_id, session_id, role, content, create_time)
        VALUES (#{userId}, #{sessionId}, #{role}, #{content}, #{createTime})
    </insert>

</mapper>